{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenWhisper",
  "version": "0.2.0",
  "identifier": "dev.openwhisper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "OpenWhisper Settings",
        "url": "index.html#settings",
        "width": 560,
        "height": 720,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local-only voice dictation with Whisper + Gemma.",
    "longDescription": "OpenWhisper is a fully-local menu-bar dictation app. It records audio from your microphone, transcribes it with whisper.cpp, optionally cleans it up with a local Gemma 2B LLM via llama.cpp, and pastes the result into the focused text field. Nothing leaves your machine.",
    "copyright": "Copyright (c) 2026 OpenWhisper contributors",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {}
}
